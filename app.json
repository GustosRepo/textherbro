{
  "expo": {
    "name": "TextHerBro",
    "slug": "TextHerBro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.codewerx.TextHerBro",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.codewerx.TextHerBro"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "iosPermissions": [
            "Alert",
            "Badge",
            "Sound"
          ],
          "ios": {
            "NSUserNotificationsUsageDescription": "TextHerBro sends daily reminders to help you stay consistent with your partner."
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "42703460-f6b0-4de6-be83-76726278db74"
      }
    },
    "owner": "codewerx"
  }
}
